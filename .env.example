# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/beachtravel

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Groq (LLM provider)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_MS=20000

# RAG vector store (ChromaDB) — see docker-compose for the local container
CHROMA_URL=http://localhost:8000

# CORS: comma-separated list of allowed frontend origins in production.
# Leave empty in local development to allow any origin (previous behavior).
CORS_ORIGINS=https://your-frontend-domain.com

# Logging
LOG_LEVEL=info

# Redis (used starting in the distributed-system-readiness phase)
REDIS_URL=redis://localhost:6379
